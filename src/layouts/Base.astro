---
import '../styles/global.css';

interface Props {
  title?: string;
  lang?: 'en' | 'ar';
}

const { title = 'Jisr Regulatory Hub', lang = 'en' } = Astro.props;
const dir = lang === 'ar' ? 'rtl' : 'ltr';
---
<!doctype html>
<html lang={lang} dir={dir}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Plain-language Saudi HR law — updated to reflect the February 2025 amendments (Royal Decree M/44)." />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>
  <slot />
</body>
</html>
